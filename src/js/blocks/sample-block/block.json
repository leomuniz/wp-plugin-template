{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wp-plugin-template/sample-block",
	"version": "1.0.0",
	"title": "Sample Block",
	"category": "widgets",
	"icon": "smiley",
